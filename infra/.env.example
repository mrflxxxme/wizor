# WIZOR dev — пример окружения. Скопируй в infra/.env и заполни.
# НИКОГДА не коммить реальные значения (§6.9). Prod-секреты — в Yandex Lockbox.
# Регион хранения/обработки ПД — только РФ (NFR-1, инвариант §6.6).

# --- Postgres (dev-дефолты безопасны для локалки) ---
POSTGRES_USER=wizor
POSTGRES_PASSWORD=wizor
POSTGRES_DB=wizor

# --- Keycloak admin (dev) ---
KEYCLOAK_ADMIN=admin
KEYCLOAK_ADMIN_PASSWORD=admin

# --- PostHog (NFR-7) ---
# P1: пусто → аналитика в no-op (self-hosted инстанс отложен, deferred_live_gold).
# Реальный ключ подставляется на проде/P7 (PLACEHOLDERS: POSTHOG_API_KEY).
POSTHOG_API_KEY=
POSTHOG_HOST=http://localhost:8000

# --- Backend (WIZOR_-префикс; для compose выставляются автоматически) ---
# Переопредели только при нестандартной локальной конфигурации.
# WIZOR_DATA_REGION=ru-central1            # фиксировано РФ; не менять
# WIZOR_DATABASE_URL=postgresql+asyncpg://wizor:wizor@postgres:5432/wizor
# WIZOR_REDIS_URL=redis://redis:6379/0

# --- TBD для prod (см. .planning/PLACEHOLDERS.md; реальные значения в Lockbox) ---
# YANDEX_CLOUD_FOLDER_ID=TBD
# GIGACHAT_API_KEY=TBD
# YANDEX_GPT_API_KEY=TBD
